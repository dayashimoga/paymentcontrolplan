# PCP Environment Configuration
# Copy to .env and modify for your environment

# Server
PCP_SERVER_HOST=0.0.0.0
PCP_SERVER_PORT=8080

# Database
PCP_DATABASE_HOST=localhost
PCP_DATABASE_PORT=5432
PCP_DATABASE_USER=pcp
PCP_DATABASE_PASSWORD=pcp_secret
PCP_DATABASE_NAME=pcp
PCP_DATABASE_SSL_MODE=disable

# Redis
PCP_REDIS_HOST=localhost
PCP_REDIS_PORT=6379
PCP_REDIS_PASSWORD=

# JWT
PCP_JWT_SECRET=change-me-in-production
PCP_JWT_ISSUER=pcp

# Logging
PCP_LOG_LEVEL=info
PCP_LOG_FORMAT=json
